# Copy this file to .env for local CLI testing.
# Real .env files are ignored by Git.

# Use the full Clinic portal URL as the only target input.
# CLINIC_PORTAL_URL=https://clinic.pingcap.com/portal/#/orgs/.../clusters/...
CLINIC_API_KEY=replace-me
# Required for https://clinic.pingcap.com.cn links.
# CLINIC_CN_API_KEY=replace-me

# Metrics commands
# CLINIC_METRICS_QUERY=sum(tidb_server_connections)
# CLINIC_RANGE_STEP=1m

# Cloud events
# CLINIC_EVENT_NAME=backup
# CLINIC_EVENT_SEVERITY=warning

# Slow query
# CLINIC_SLOWQUERY_ORDER_BY=query_time
# CLINIC_SLOWQUERY_LIMIT=20
# CLINIC_SLOWQUERY_DESC=true

# Cloud logs
# CLINIC_LOKI_LABEL=instance
# CLINIC_LOKI_QUERY={container="tidb"}
# CLINIC_LOKI_LIMIT=20
# CLINIC_LOKI_DIRECTION=backward

# Download commands
# CLINIC_OUTPUT_PATH=./downloads
# CLINIC_DIAGNOSTIC_KEY=replace-me
# CLINIC_PROFILE_TS=1772776800
# CLINIC_PROFILE_TYPE=cpu
# CLINIC_PROFILE_COMPONENT=tidb
# CLINIC_PROFILE_ADDRESS=10.0.0.1:10080
# CLINIC_PROFILE_DATA_FORMAT=raw

# Optional probe interval when waiting for rebuilt artifacts.
# CLINIC_REBUILD_PROBE_INTERVAL=20ms
