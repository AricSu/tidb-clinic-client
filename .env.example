# Copy this file to .env for local CLI testing.
# Real .env files are ignored by Git.

# Optional. Defaults to https://clinic.pingcap.com
# CLINIC_API_BASE_URL=https://clinic.pingcap.com
CLINIC_API_KEY=replace-me
CLINIC_CLUSTER_ID=replace-me

# Optional overrides
# CLINIC_ORG_TYPE=cloud
# CLINIC_ORG_ID=replace-me
CLINIC_METRICS_QUERY=sum(tidb_server_connections)
# CLINIC_RANGE_START=1772776800
# CLINIC_RANGE_END=1772777400
CLINIC_RANGE_STEP=1m
CLINIC_TIMEOUT_SEC=20

# Advanced SDK/shared item-scoped usage
# These are no longer public root CLI commands.
# Keep using these only when you already know CLINIC_ITEM_ID.
# CLINIC_ITEM_ID=replace-me
# CLINIC_LIMIT=10
# CLINIC_DESC=true
# CLINIC_SLOWQUERY_ORDER_BY=queryTime
# CLINIC_LOG_PATTERN=error

# On-Premise (OP) workflow commands
# These resolve CLINIC_ITEM_ID internally from catalog.
# CLINIC_ORG_TYPE=op
# CLINIC_ORG_ID=replace-me
# CLINIC_CLUSTER_ID=replace-me

# Cloud event detail
# CLINIC_EVENT_ID=replace-me

# Cloud TopSQL
# CLINIC_CLOUD_COMPONENT=tidb
# CLINIC_CLOUD_INSTANCE=tidb-0
# CLINIC_CLOUD_START=1772776800
# CLINIC_CLOUD_END=1772777400
# CLINIC_CLOUD_TOP=5
# CLINIC_CLOUD_WINDOW=60s
# CLINIC_CLOUD_GROUP_BY=query

# Cloud slow query commands
# CLINIC_CLOUD_HOURS=1
# CLINIC_CLOUD_ORDER_BY=sum_latency
# CLINIC_CLOUD_LIMIT=10
# CLINIC_CLOUD_DIGEST=replace-me
# CLINIC_CLOUD_DESC=true
# CLINIC_CLOUD_FIELDS=query,timestamp,query_time,memory_max,request_count,connection_id
# CLINIC_CLOUD_CONNECTION_ID=replace-me
# CLINIC_CLOUD_TIMESTAMP=replace-me
