# Copy this file to .env for local CLI testing.
# Real .env files are ignored by Git.

# Optional. Defaults to https://clinic.pingcap.com
# CLINIC_API_BASE_URL=https://clinic.pingcap.com
CLINIC_API_KEY=replace-me
CLINIC_CLUSTER_ID=replace-me

# Optional overrides
CLINIC_METRICS_QUERY=sum(tidb_server_connections)
# CLINIC_RANGE_START=1772776800
# CLINIC_RANGE_END=1772777400
CLINIC_RANGE_STEP=1m
CLINIC_TIMEOUT_SEC=20
# CLINIC_ORG_ID=replace-me

# Capability-first retrieval helpers
# These commands resolve item selection inside the SDK facade when possible.
# CLINIC_LIMIT=10
# CLINIC_DESC=true
# CLINIC_SLOWQUERY_ORDER_BY=queryTime
# CLINIC_LOG_PATTERN=error

# Cloud event detail
# CLINIC_EVENT_ID=replace-me

# TopSQL summary
# CLINIC_COMPONENT=tidb
# CLINIC_INSTANCE=tidb-0
# CLINIC_TOPSQL_WINDOW=60s
# CLINIC_TOPSQL_GROUP_BY=query

# Slow query commands
# CLINIC_SLOWQUERY_DIGEST=replace-me
# CLINIC_SLOWQUERY_ID=replace-me
# CLINIC_SLOWQUERY_CONNECTION_ID=replace-me
# CLINIC_SLOWQUERY_TIMESTAMP=replace-me
# CLINIC_SLOWQUERY_FIELDS=query,timestamp,query_time,memory_max,request_count,connection_id
